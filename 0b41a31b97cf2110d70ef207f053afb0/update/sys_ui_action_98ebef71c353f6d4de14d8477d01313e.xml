        <script><![CDATA[function devops_openExecutions() {
	var openInNewTab = event?.ctrlKey;
	fetch('/api/now/stats/sys_update_version?' + new URLSearchParams({
		sysparm_query: 'name=' + g_form.getTableName() + '_' + g_form.getUniqueValue() + '^action=INSERT_OR_UPDATE',
		sysparm_group_by: 'record_name',
		sysparm_count: 'true'
	}), {
		headers: {
			'X-UserToken': g_ck
		}
	}).then(response => response.json())
	.then(json => json.result.map(res => res.groupby_fields[0].value))
	.then(names => {
		var query = names.map(name => 'name=Fix Script: ' + name).join('^OR');
		if (openInNewTab) {
			g_navigation.open('sys_progress_worker_list.do?sysparm_query=' + encodeURIComponent(query));
		} else {
			var gm = new GlideModalForm('Executions', 'sys_progress_worker_list');
			gm.addParm('sysparm_query', query);
			gm.render();
		}
	});
}]]></script>
