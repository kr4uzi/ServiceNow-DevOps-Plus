        <name>Open Rollback Context</name>
        <onclick>devops_openRollbackContext()</onclick>
        <order>100</order>
        <script><![CDATA[function devops_openRollbackContext() {
	if (!g_scratchpad.dev_ops_plus_rollback_context) {
		g_form.addErrorMessage('No Rollback Context found!');
		return;
	}

	var openInNewTab = event?.ctrlKey;
	if (openInNewTab) {
		g_navigation.open('sys_rollback_context.do?sys_id=' + g_scratchpad.dev_ops_plus_rollback_context.sys_id, '_blank');
	} else {
		var gm = new GlideModalForm('Rollback Context: ' + g_scratchpad.dev_ops_plus_rollback_context.display_value, 'sys_rollback_context');
		gm.setSysID(g_scratchpad.dev_ops_plus_rollback_context.sys_id);
		gm.render();
	}
}]]></script>
